generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  OWNER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TripType {
  ONE_WAY
  ROUND_TRIP
}

enum SeatClass {
  BUSINESS
  FIRST_CLASS
  VIP
}

enum TripStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMethod {
  MPESA
  CASH
  CARD
}

enum SupportTicketStatus {
  OPEN
  IN_REVIEW
  ESCALATED
  RESOLVED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum SupportTicketCategory {
  BOOKING
  PAYMENT
  DISPUTE
  APP_BUG
  GENERAL
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
}

enum NotificationTargetRole {
  ADMIN
  OWNER
  USER
  ALL
}

enum NotificationStatus {
  DRAFT
  SCHEDULED
  SENT
  CANCELLED
}

enum HelpArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id           String        @id @default(uuid())
  firstName    String
  lastName     String
  email        String        @unique
  phone        String?       @unique
  password     String
  role         UserRole      @default(USER)
  status       UserStatus    @default(ACTIVE)
  isVerified   Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  ownerProfile OwnerProfile?
  bookings     Booking[]
  payments     Payment[]
}

model OwnerProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  businessEmail String?
  businessPhone String?
  kraPin        String?
  licenseNumber String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sacco         Sacco?
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  saccos      Sacco[]
}

model Sacco {
  id            String       @id @default(uuid())
  ownerProfileId String      @unique
  categoryId    String
  name          String
  slug          String       @unique
  logoUrl       String?
  supportPhone  String?
  supportEmail  String?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  ownerProfile  OwnerProfile @relation(fields: [ownerProfileId], references: [id], onDelete: Cascade)
  category      Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  buses         Bus[]
  trips         Trip[]

  @@index([categoryId])
}

model Route {
  id              String    @id @default(uuid())
  origin          String
  destination     String
  distanceKm      Float?
  estimatedTime   Int?      // in minutes
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  trips           Trip[]

  @@index([origin, destination])
}

model Bus {
  id            String    @id @default(uuid())
  saccoId       String
  name          String
  plateNumber   String    @unique
  seatCapacity  Int
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sacco         Sacco     @relation(fields: [saccoId], references: [id], onDelete: Cascade)
  seats         Seat[]
  trips         Trip[]

  @@index([saccoId])
}

model Seat {
  id            String    @id @default(uuid())
  busId         String
  seatNumber    String
  seatClass     SeatClass
  price         Decimal   @db.Decimal(10, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bus           Bus       @relation(fields: [busId], references: [id], onDelete: Cascade)
  bookings      Booking[]

  @@unique([busId, seatNumber])
  @@index([busId, seatClass])
}

model Trip {
  id             String      @id @default(uuid())
  saccoId        String
  busId          String
  routeId        String
  tripType       TripType    @default(ONE_WAY)
  departureTime  DateTime
  arrivalTime    DateTime
  basePrice      Decimal     @db.Decimal(10, 2)
  aiAnalysis     String?
  status         TripStatus  @default(SCHEDULED)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  sacco          Sacco       @relation(fields: [saccoId], references: [id], onDelete: Cascade)
  bus            Bus         @relation(fields: [busId], references: [id], onDelete: Cascade)
  route          Route       @relation(fields: [routeId], references: [id], onDelete: Restrict)
  bookings       Booking[]

  @@index([saccoId])
  @@index([busId])
  @@index([routeId])
  @@index([departureTime])
  @@index([status])
}

model Booking {
  id              String         @id @default(uuid())
  userId          String
  tripId          String
  seatId          String
  bookingCode     String         @unique
  firstName       String
  lastName        String
  email           String?
  phone           String
  nationalId      String
  residence       String?
  amount          Decimal        @db.Decimal(10, 2)
  aiAnalysis      String?
  status          BookingStatus  @default(PENDING)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip            Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  seat            Seat           @relation(fields: [seatId], references: [id], onDelete: Restrict)
  payment         Payment?

  @@unique([tripId, seatId])
  @@index([userId])
  @@index([tripId])
  @@index([status])
}

model Payment {
  id                 String         @id @default(uuid())
  userId             String
  bookingId          String         @unique
  method             PaymentMethod  @default(MPESA)
  amount             Decimal        @db.Decimal(10, 2)
  phoneNumber        String
  transactionRef     String?        @unique
  checkoutRequestId  String?        @unique
  merchantRequestId  String?        @unique
  aiAnalysis         String?
  status             PaymentStatus  @default(PENDING)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking            Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model PlatformSetting {
  id                    String   @id @default("default")
  commissionRate        Int      @default(5)
  minimumFare           Int      @default(50)
  aiPricing             Boolean  @default(true)
  fraudBlockThreshold   Int      @default(80)
  delayRiskAlert        String   @default("medium")
  voiceLanguages        String   @default("en-sw")
  smsBooking            Boolean  @default(true)
  emailTicket           Boolean  @default(true)
  pushDeparture         Boolean  @default(true)
  pushNotifications     Boolean  @default(true)
  saccoRevenueReport    Boolean  @default(false)
  adminFraudAlert       Boolean  @default(true)
  sessionTimeoutMinutes Int      @default(60)
  maxFailedLogins       Int      @default(5)
  require2fa            Boolean  @default(true)
  version               String   @default("3.0.0")
  environment           String   @default("Production")
  build                 String   @default("20260319")
  apiStatus             String   @default("Operational")
  updatedAt             DateTime @updatedAt
}

model SupportTicket {
  id          String               @id @default(uuid())
  ticketCode  String               @unique
  subject     String
  userName    String
  category    SupportTicketCategory
  priority    SupportTicketPriority
  status      SupportTicketStatus  @default(OPEN)
  assignedTo  String?
  description String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([status])
  @@index([category])
  @@index([priority])
  @@index([createdAt])
}

model AdminNotification {
  id          String                 @id @default(uuid())
  title       String
  message     String
  channel     NotificationChannel
  targetRole  NotificationTargetRole @default(ALL)
  status      NotificationStatus     @default(DRAFT)
  scheduledFor DateTime?
  sentAt      DateTime?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([status])
  @@index([channel])
  @@index([targetRole])
  @@index([createdAt])
}

model HelpArticle {
  id            String            @id @default(uuid())
  title         String
  slug          String            @unique
  category      String
  content       String
  status        HelpArticleStatus @default(PUBLISHED)
  isAiGenerated Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status])
  @@index([category])
  @@index([createdAt])
}